# ════════════════════════════════════════════════════════════════════
# Root .gitignore — Bảo vệ toàn bộ project khỏi leak credentials
# ════════════════════════════════════════════════════════════════════

# ─── Secrets & Credentials ────────────────────────────────────────
# File override chứa credentials thật, không được commit
docker-compose.override.yml

# Biến môi trường
.env
.env.local
.env.production
.env.*.local
*.env

# Firebase service account key
firebase-service-account.json
*-service-account.json

# Certificates & private keys
*.pem
*.key
*.p12
*.jks

# ─── Backend (Spring Boot) ────────────────────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/.idea/
backend/*.iws
backend/*.iml
backend/*.ipr
backend/.classpath
backend/.project
backend/.settings/
backend/.springBeans
backend/.sts4-cache/
backend/.vscode/

# ─── Frontend (React + Vite) ─────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vscode/
frontend/.DS_Store

# ─── Video Service (Node.js) ─────────────────────────────────────
video-service/node_modules/
video-service/dist/
video-service/out/
video-service/*.mp4
video-service/*.mp3

# ─── Mobile (Flutter) ────────────────────────────────────────────
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/build/
mobile/.idea/
mobile/*.iml
mobile/android/.gradle/
mobile/android/local.properties
mobile/ios/.symlinks/
mobile/ios/Pods/

# ─── OS & Editor ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.sw?

# ─── Logs ─────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
