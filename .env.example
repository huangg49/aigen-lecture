# ─── CORE ─────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── RESILIENCE & PERFORMANCE ─────────────
# Maximum simultaneous Remotion video rendering jobs on EC2
MAX_CONCURRENT_RENDERS=1

# Maximum minutes a job can remain in PROCESSING before being marked FAILED
JOB_TIMEOUT_MINUTES=20

# ─── DEPLOYMENT (EC2) ─────────────
# Set these when deploying to EC2. Replace <EC2_PUBLIC_IP> with your instance's IP.
# VITE_API_BASE_URL=http://<EC2_PUBLIC_IP>:8080/api
# APP_CORS_ALLOWED_ORIGINS=http://<EC2_PUBLIC_IP>,http://<EC2_PUBLIC_IP>:80
