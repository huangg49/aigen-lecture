PORT=3001
TTS_PROVIDER=mock

# ElevenLabs TTS (chỉ dùng khi có gói trả phí)
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=your-api-key-here

# ─── Supabase Storage (lưu video lên cloud sau khi render) ───────────
# Đặt UPLOAD_TO_SUPABASE=true khi deploy production.
# Để false (hoặc không set) khi dev local — video sẽ được serve qua localhost.
UPLOAD_TO_SUPABASE=false
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_BUCKET_NAME=lecture-videos
