@startuml SD-09_StudentQuiz
!theme cerulean-outline
title SD-09: Student — Lam Trac Nghiem Sau Khi Xem Video

actor Student
participant "Frontend\n(React + Vite)" as FE
participant "InteractionController" as ICtrl
participant "InteractionService" as ISvc
participant "AiElementRepository" as AiRepo
database "PostgreSQL" as DB

== Lay danh sach cau hoi ==
Student -> FE : Click "Lam bai kiem tra"
FE -> ICtrl : GET /api/lectures/{lectureId}/quizzes\nAuthorization: Bearer <JWT>

note over ICtrl : correctAnswer = null khi Student goi\n(an de chong gian lan — BR-Student)

ICtrl -> ISvc : getQuizzesByLecture(lectureId, principal)
ISvc -> AiRepo : findByLecture_LectureId(lectureId)
AiRepo -> DB : SELECT * FROM ai_elements\nWHERE lecture_id = ?\nORDER BY order_index
DB --> AiRepo : List<AiElement>
ISvc -> ISvc : Map sang QuizResponse\nan correctAnswer neu la STUDENT
ISvc --> ICtrl : List<QuizResponse>
ICtrl --> FE : 200 OK\n[{elementId, questionText,\n  options:[A,B,C,D],\n  correctAnswer: null}]
FE --> Student : Hien thi form quiz\n(multiple choice)

== Nop cau tra loi ==
Student -> FE : Chon dap an va Submit
FE -> ICtrl : POST /api/interactions\n{elementId, submittedAnswer: "B", timeSpent: 30}
ICtrl -> ISvc : submitAnswer(studentId, request)
ISvc -> AiRepo : findById(elementId)
AiRepo -> DB : SELECT * FROM ai_elements\nWHERE element_id = ?
DB --> AiRepo : AiElement {correctAnswer: "B"}

ISvc -> ISvc : isCorrect = ("B" == "B") → true\nKiem tra isFirstAttempt (interaction_logs)
ISvc -> DB : INSERT INTO interaction_logs\n{student_id, element_id,\n submitted_answer, is_correct, time_spent}
DB --> ISvc : InteractionLog {logId}

ISvc --> ICtrl : SubmitAnswerResponse
ICtrl --> FE : 200 OK\n{logId, elementId,\n submittedAnswer: "B",\n isCorrect: true,\n correctAnswer: "B",\n isFirstAttempt: true}
FE --> Student : Hien thi ket qua\n(dung/sai, dap an dung, giai thich)
@enduml
