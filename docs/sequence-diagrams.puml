@startuml SD-05_BackendPolling
!theme cerulean-outline
title SD-05: Backend — Scheduled Polling Video Status (moi 15 giay)

participant "Spring Scheduler\n(@Scheduled)" as Sched
participant "LectureService\n(pollVideoServiceStatus)" as LSvc
participant "LectureRepository" as LRepo
database "PostgreSQL" as DB
participant "VideoService\n(Node.js)" as VideoSvc
participant "RenderJob\n(In-Memory)" as RenderJob

loop Moi 15 giay (fixedDelay = 15_000)
    Sched -> LSvc : pollVideoServiceStatus()
    LSvc -> LRepo : findByVideoStatusIn([PROCESSING])
    LRepo -> DB : SELECT * FROM lectures\nWHERE video_status = 'PROCESSING'
    DB --> LRepo : List<Lecture>
    LRepo --> LSvc : processingLectures

    alt processingLectures rong
        LSvc -> LSvc : return (bo qua vong nay)
    else Co lecture dang PROCESSING
        loop Moi lecture trong processingLectures
            LSvc -> VideoSvc : GET /video-status/{videoJobId}
            VideoSvc -> RenderJob : getJob(jobId)
            RenderJob --> VideoSvc : job {status, videoUrl, error}
            VideoSvc --> LSvc : 200 OK\n{jobId, lectureId, status, videoUrl, error}

            alt status = "done"
                LSvc -> LRepo : save(lecture)\n  videoStatus = DONE\n  videoUrl = json.videoUrl
                LRepo -> DB : UPDATE lectures\nSET video_status='DONE', video_url=?
            else status = "failed"
                LSvc -> LRepo : save(lecture)\n  videoStatus = FAILED
                LRepo -> DB : UPDATE lectures\nSET video_status='FAILED'
            else status = "pending" | "processing"
                LSvc -> LSvc : log.debug — cho poll lan sau
            end
        end
    end
end
@enduml

