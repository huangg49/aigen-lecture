@startuml SD-03_CreateLecture
!theme cerulean-outline
title SD-03: Teacher — Tao Bai Giang & Trigger Video Generation (Async)

actor Teacher
participant "Frontend\n(React + Vite)" as FE
participant "LectureController" as LCtrl
participant "LectureService" as LSvc
participant "AiElementRepository" as AiRepo
participant "LectureRepository" as LRepo
database "PostgreSQL" as DB
participant "@Async Thread\n(triggerVideoGeneration)" as AsyncThread
participant "VideoService\n(Node.js + Express)" as VideoSvc

Teacher -> FE : Xem preview slides, nhan "Tao bai giang"
FE -> LCtrl : POST /api/lectures\nAuthorization: Bearer <JWT>\n{title, originalSource, slides:[...], quizzes:[...]}

note over LCtrl : @PreAuthorize("hasRole('TEACHER')")\nLayteacherId tu JWT (UserPrincipal)

LCtrl -> LSvc : createLecture(teacherId, request)
LSvc -> LRepo : findById(teacherId)
LRepo -> DB : SELECT * FROM users WHERE user_id = ?
DB --> LRepo : User entity

LSvc -> LSvc : new Lecture()\nlecture.setVideoStatus(PENDING)
LSvc -> LRepo : save(lecture)
LRepo -> DB : INSERT INTO lectures\n(video_status = 'PENDING')
DB --> LRepo : Lecture {lectureId}

loop Moi quiz trong request.quizzes
    LSvc -> AiRepo : save(AiElement)\n{lectureId, questionText, options, correctAnswer, orderIndex}
    AiRepo -> DB : INSERT INTO ai_elements
end

LSvc -> AsyncThread : triggerVideoGeneration(lectureId, request)\n[Fire-and-forget @Async]

note over AsyncThread : Chay trong thread pool rieng\nKHONG block request thread

LSvc --> LCtrl : LectureResponse\n{lectureId, videoStatus: PENDING, videoUrl: null}
LCtrl --> FE : 202 Accepted\n{lectureId, title, videoStatus: "PENDING", ...}
FE --> Teacher : Chuyen sang trang chi tiet\nvà bat dau Poll video status

== Async Thread: Goi Video Service ==
AsyncThread -> AsyncThread : Build JSON:\n{lectureId, slides:[{title, bulletPoints, narrationText}]}
AsyncThread -> VideoSvc : POST /generate-video\n{lectureId, slides:[...]}

alt activeJobs >= 3 (qua tai)
    VideoSvc --> AsyncThread : 429 Too Many Requests
    AsyncThread -> LRepo : lecture.videoStatus = FAILED
    LRepo -> DB : UPDATE lectures SET video_status = 'FAILED'
else Thanh cong
    VideoSvc --> AsyncThread : 202 Accepted\n{jobId: "uuid", status: "pending"}
    AsyncThread -> LRepo : lecture.videoJobId = jobId\nlecture.videoStatus = PROCESSING
    LRepo -> DB : UPDATE lectures SET\n  video_job_id = ?,\n  video_status = 'PROCESSING'
end
@enduml

