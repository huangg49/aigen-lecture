@startuml SD-04_VideoRenderPipeline
!theme cerulean-outline
title SD-04: Video Service — Pipeline Render Video (Noi bo)

participant "VideoService\n(Express /generate-video)" as Server
participant "RenderJob\n(In-Memory Map)" as RenderJob
participant "runRenderPipeline\n(Async)" as Pipeline
participant "Webpack Bundle\n(Remotion)" as Bundle
participant "TtsProvider\n(Mock / ElevenLabs)" as TTS
participant "Remotion\n(Chromium + FFmpeg)" as Remotion
participant "Supabase Storage\n(hoac local)" as Storage

note over Server : Da nhan POST /generate-video\nvà tra ve 202 voi jobId

Server -> Pipeline : setImmediate(() =>\n  runRenderPipeline(jobId, request))
note over Pipeline : Fire-and-forget\nkhong block request

Pipeline -> RenderJob : updateJob(jobId, {status: "processing"})
Pipeline -> Pipeline : activeJobs++

Pipeline -> Bundle : getBundlePath()\n(lazy init cache)

alt cachedBundlePath da co
    Bundle --> Pipeline : cachedBundlePath (string)
else Lan dau tien (cold start)
    Bundle -> Bundle : bundle({entryPoint:\n  "src/remotion/index.ts"})
    note over Bundle : Webpack bundle 1 lan duy nhat\n~10-30s khi server khoi dong
    Bundle --> Pipeline : bundlePath
end

loop Moi slide trong request.slides
    Pipeline -> TTS : tts.synthesize(slide.narrationText)
    note over TTS : mock: tra ve audio gia lap\nelevenlabs: goi ElevenLabs API
    TTS --> Pipeline : {audioUrl, durationMs}
    Pipeline -> Pipeline : slide.audioUrl = audioUrl\nslideDurationsFrames.push(frames)
end

Pipeline -> Pipeline : totalFrames = sum(slideDurationsFrames)\ninputProps = {slides, slideDurationsFrames}

Pipeline -> Remotion : selectComposition({serveUrl,\n  id: "SlideComposition", inputProps})
Remotion --> Pipeline : composition
Pipeline -> Pipeline : composition.durationInFrames = totalFrames

Pipeline -> Remotion : renderMedia({composition,\n  codec: "h264",\n  outputLocation: "out/{jobId}.mp4",\n  inputProps})
note over Remotion : Render tung frame bang Chromium\nEncode MP4 bang FFmpeg\n(mat vai phut tuy do dai video)
Remotion --> Pipeline : "out/{jobId}.mp4" da render xong

alt UPLOAD_TO_SUPABASE = "true"
    Pipeline -> Storage : uploadVideoToSupabase(localPath, jobId)\nsupabase.storage.from(bucket).upload(...)
    Storage --> Pipeline : publicUrl (string)
    Pipeline -> Pipeline : Xoa file local sau upload
else Moi truong local (dev)
    Pipeline -> Pipeline : videoUrl =\n"http://localhost:{PORT}/videos/{jobId}.mp4"
end

Pipeline -> RenderJob : updateJob(jobId,\n{status: "done", videoUrl})
Pipeline -> Pipeline : activeJobs--
@enduml

