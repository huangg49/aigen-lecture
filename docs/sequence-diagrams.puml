@startuml SD-07_StudentViewLecture
!theme cerulean-outline
title SD-07: Student — Xem Danh Sach & Xem Video Bai Giang

actor Student
participant "Frontend\n(React + Vite)" as FE
participant "LectureController" as LCtrl
participant "LectureService" as LSvc
database "PostgreSQL" as DB
participant "Video Storage\n(Supabase / local)" as Storage

== Xem danh sach bai giang ==
Student -> FE : Vao trang "Danh sach bai giang"
FE -> LCtrl : GET /api/lectures/student\nAuthorization: Bearer <JWT>\n?page=0&size=10&title=...

note over LCtrl : @PreAuthorize("hasRole('STUDENT')")\nKhong co ownership check

LCtrl -> LSvc : getAllLecturesForStudent(titleKeyword, pageable)
LSvc -> DB : SELECT * FROM lectures\nWHERE title LIKE '%keyword%'\nORDER BY created_at DESC LIMIT 10
DB --> LSvc : Page<Lecture>
LSvc --> LCtrl : Page<LectureResponse>
LCtrl --> FE : 200 OK\n{content:[{lectureId, title, teacherName,\n  videoStatus, videoUrl,...}],\n totalElements, totalPages}
FE --> Student : Hien thi danh sach bai giang\n(card voi tieu de, trang thai, giao vien)

== Xem chi tiet & Video ==
Student -> FE : Click vao bai giang
FE -> LCtrl : GET /api/lectures/{id}\nAuthorization: Bearer <JWT>
LCtrl -> LSvc : getLecture(id, studentId, principal)
note over LSvc : Student khong bi kiem tra ownership\n(chi TEACHER moi bi BR-02)
LSvc -> DB : SELECT * FROM lectures WHERE lecture_id = ?
DB --> LSvc : Lecture entity
LSvc --> LCtrl : LectureResponse
LCtrl --> FE : 200 OK\n{lectureId, title, videoStatus, videoUrl, ...}

alt videoStatus = "DONE" va videoUrl != null
    FE -> Storage : GET {videoUrl} — MP4 stream
    Storage --> FE : Video stream
    FE --> Student : Hien thi Video Player\n(play, pause, seekbar)
else videoStatus != "DONE"
    FE --> Student : Hien thi trang thai\n(PENDING / PROCESSING / FAILED)
end
@enduml

