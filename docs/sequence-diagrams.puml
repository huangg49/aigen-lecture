@startuml SD-06_FrontendPolling
!theme cerulean-outline
title SD-06: Frontend — Poll Video Status & Hien Thi Video Player

actor Teacher
participant "Frontend\n(React + Vite)" as FE
participant "LectureController" as LCtrl
participant "LectureService" as LSvc
database "PostgreSQL" as DB

note over FE : Sau khi POST /api/lectures tra ve 202,\nFE bat dau vong lap polling moi 3 giay

loop Moi 3 giay (setInterval) cho den khi DONE / FAILED
    FE -> LCtrl : GET /api/lectures/{lectureId}/video-status\n(Public endpoint — khong can JWT)
    LCtrl -> LSvc : getVideoStatus(lectureId)
    LSvc -> DB : SELECT * FROM lectures\nWHERE lecture_id = ?
    DB --> LSvc : Lecture entity
    LSvc --> LCtrl : Lecture {videoStatus, videoUrl}
    LCtrl --> FE : 200 OK\n{lectureId, videoStatus, videoUrl, errorMessage}

    alt videoStatus = "PENDING"
        FE --> Teacher : Hien thi spinner: "Dang chuan bi..."
    else videoStatus = "PROCESSING"
        FE --> Teacher : Hien thi progress bar: "Dang render video..."
    else videoStatus = "DONE"
        FE -> FE : clearInterval() — dung polling
        FE --> Teacher : Hien thi Video Player\nvoi videoUrl (MP4)
    else videoStatus = "FAILED"
        FE -> FE : clearInterval() — dung polling
        FE --> Teacher : Hien thi thong bao loi
    end
end
@enduml

