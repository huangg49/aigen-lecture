@startuml SD-01_Auth
!theme cerulean-outline
title SD-01: Authentication — Dang ky & Dang nhap

actor "User\n(Teacher/Student)" as User
participant "Frontend\n(React + Vite)" as FE
participant "AuthController\n(Spring Boot)" as Auth
participant "UserRepository\n(JPA)" as UserRepo
participant "JwtTokenProvider" as JWT
database "PostgreSQL" as DB

== Dang ky ==
User -> FE : Nhap name, email, password, role
FE -> Auth : POST /api/auth/register\n{name, email, password, role}
Auth -> UserRepo : existsByEmail(email)
UserRepo -> DB : SELECT COUNT(*) WHERE email = ?
DB --> UserRepo : count
UserRepo --> Auth : true / false

alt Email da ton tai
    Auth --> FE : 400 Bad Request\n{"error": "Email da duoc su dung"}
    FE --> User : Hien thi loi
else Email moi
    Auth -> Auth : BCrypt.encode(password)
    Auth -> UserRepo : save(user)
    UserRepo -> DB : INSERT INTO users
    DB --> UserRepo : User (voi userId)
    Auth -> JWT : generateToken(UserPrincipal)
    JWT --> Auth : jwtToken (string)
    Auth --> FE : 200 OK\n{token, userId, name, email, role}
    FE --> User : Chuyen huong vao Dashboard
end

== Dang nhap ==
User -> FE : Nhap email, password
FE -> Auth : POST /api/auth/login\n{email, password}
Auth -> UserRepo : findByEmail(email)
UserRepo -> DB : SELECT * FROM users WHERE email = ?
DB --> UserRepo : User entity

alt Sai email hoac password
    Auth --> FE : 401 Unauthorized
    FE --> User : Hien thi loi
else Tai khoan bi vo hieu hoa
    Auth --> FE : 400 Bad Request
    FE --> User : "Tai khoan da bi vo hieu hoa"
else Thanh cong
    Auth -> JWT : generateToken(UserPrincipal)
    JWT --> Auth : jwtToken
    Auth --> FE : 200 OK {token, userId, name, email, role}
    FE -> FE : Luu token vao Zustand store
    FE --> User : Chuyen huong vao Dashboard
end
@enduml

' ============================================================

@startuml SD-02_GenerateFromFile
!theme cerulean-outline
title SD-02: Teacher — Upload File & AI Sinh Kich Ban Bai Giang

actor Teacher
participant "Frontend\n(React + Vite)" as FE
participant "LectureController" as LCtrl
participant "DocumentParserService" as DocParser
participant "LlmService" as LLM
participant "Gemini API\n(Google)" as Gemini

Teacher -> FE : Chon file PDF/DOCX/PPTX\nvà nhan "Sinh kich ban"
FE -> LCtrl : POST /api/lectures/generate-from-file\nAuthorization: Bearer <JWT>\nContent-Type: multipart/form-data

note over LCtrl : @PreAuthorize("hasRole('TEACHER')")\nXac thuc JWT token

LCtrl -> DocParser : parseDocument(multipartFile)

alt file.endsWith(".pdf")
    DocParser -> DocParser : parsePdf() — PDFBox PDFTextStripper
else file.endsWith(".docx")
    DocParser -> DocParser : parseDocx() — Apache POI XWPFWordExtractor
else file.endsWith(".pptx")
    DocParser -> DocParser : parsePptx() — Apache POI XMLSlideShow
else Loai file khong hop le (BR-01)
    DocParser --> LCtrl : IllegalArgumentException\n"Unsupported file type"
    LCtrl --> FE : 400 Bad Request
    FE --> Teacher : Hien thi loi dinh dang
end

DocParser --> LCtrl : extractedText (String)

note over LLM : Timeout: connect=5s, read=20s\n(BR-03: LLM API timeout ~15s)

LCtrl -> LLM : generateLectureScript(extractedText)
LLM -> LLM : Xay dung prompt voi\ncau truc JSON bat buoc\n(slides + quizzes)
LLM -> Gemini : POST {geminiApiUrl}?key={apiKey}\n{contents, generationConfig:\n  {responseMimeType: "application/json"}}
Gemini --> LLM : 200 OK\n{candidates:[{content:{parts:[{text:"...JSON..."}]}}]}

LLM -> LLM : Trich xuat aiText tu candidates[0]\nClean markdown neu co
LLM -> LLM : objectMapper.readValue(aiText,\nLectureGenerateResponse.class)

alt Parse JSON thanh cong
    LLM --> LCtrl : LectureGenerateResponse\n{slides: [...], quizzes: [...]}
    LCtrl --> FE : 200 OK\n{slides:[{title, bulletPoints, narrationText},...],\n quizzes:[{questionText, options, correctAnswer},...]}
    FE --> Teacher : Hien thi preview slides + quizzes\n(cho phep chinh sua truoc khi tao)
else Timeout hoac loi API
    LLM --> LCtrl : RuntimeException("AI service timeout")
    LCtrl --> FE : 500 Internal Server Error
    FE --> Teacher : "AI service timeout, vui long thu lai"
end
@enduml

