@startuml AD-03_StudentLearningFlow
!theme cerulean-outline
title AD-03: Quy Trinh Hoc Cua Hoc Sinh

|#LightYellow| Student |
|#LightBlue|  Frontend (React) |
|#LightGreen| Backend (Spring Boot) |
|#Lavender| Storage (Supabase/local) |

|Student|
start
:Dang nhap he thong\n(role = STUDENT);

|Frontend (React)|
:GET /api/lectures/student\n?page=0&size=10&title=...;

|Backend (Spring Boot)|
:@PreAuthorize("hasRole('STUDENT')")\nValidate JWT;
:getAllLecturesForStudent()\nQuery tat ca lectures co phan trang;
:Tra ve Page<LectureResponse>\n{content[], totalElements, totalPages};

|Frontend (React)|
:Hien thi danh sach bai giang\n(card: tieu de, giao vien, trang thai video);

|Student|
:Tim kiem bai giang\n(theo tieu de);

|Frontend (React)|
:GET /api/lectures/student\n?title=keyword&page=...;
:Cap nhat danh sach loc;

|Student|
:Chon bai giang de hoc;

|Frontend (React)|
:GET /api/lectures/{id};

|Backend (Spring Boot)|
:getLecture(id, studentId, principal);
note right: Student KHONG bi kiem tra\nownership (chi TEACHER bi BR-02)
:Tra ve LectureResponse\n{videoStatus, videoUrl, ...};

|Frontend (React)|
if (videoStatus?) then (DONE)
  :Hien thi Video Player\nvoi URL tu storage;

  |Storage (Supabase/local)|
  :Stream MP4 video;

  |Frontend (React)|
  :Student xem video bai giang\n(co controls: play/pause/seek);

  |Student|
  :Xem het video;

  |Frontend (React)|
  if (Bai giang co quiz?) then (Co)
    :Hien thi nut\n"Lam bai kiem tra";

    |Student|
    :Click "Lam bai kiem tra";

    |Frontend (React)|
    :GET /api/lectures/{id}/quizzes;

    |Backend (Spring Boot)|
    :getQuizzes(lectureId, isTeacher=false)\nAn correctAnswer cho Student;
    :Tra ve [{elementId, questionText,\n  options[], correctAnswer: null}];

    |Frontend (React)|
    :Hien thi cac cau hoi\nmot luot (hoac tung cau);

    |Student|
    repeat
      :Doc cau hoi;
      :Chon dap an (A/B/C/D);
      :Nhan "Nop cau nay";

      |Frontend (React)|
      :POST /api/interactions\n{elementId, submittedAnswer, timeSpent};

      |Backend (Spring Boot)|
      :submitAnswer(studentId, request);
      :Lay AiElement tu DB;
      :isCorrect = (submitted == correct)\n(case-insensitive);
      :isFirstAttempt = kiem tra\ninteraction_logs (BR-06);
      :Luu InteractionLog vao DB;
      :Tra ve {isCorrect, correctAnswer,\n  isFirstAttempt};

      |Frontend (React)|
      if (isCorrect?) then (Dung)
        :Hien thi icon xanh\n"Chinh xac!";
      else (Sai)
        :Hien thi icon do\n"Sai. Dap an dung: X";
      endif

      |Student|
    repeat while (Con cau hoi?) is (Co)
    -> Het tat ca cau hoi;

    |Frontend (React)|
    :Hien thi ket qua tong hop\n(so cau dung / tong so cau);
    |Student|
    :Xem ket qua quiz;

  else (Khong)
    |Student|
    :Hoan thanh bai hoc;
  endif

else if (videoStatus?) then (PENDING / PROCESSING)
  :Hien thi trang thai\n"Video dang duoc xu ly...";
  :Auto refresh moi 3 giay\nden khi DONE / FAILED;
  stop
else (FAILED)
  :Hien thi "Video bi loi\nVui long lien he giao vien";
  stop
endif

|Student|
:Ket thuc phien hoc;
stop
@enduml
